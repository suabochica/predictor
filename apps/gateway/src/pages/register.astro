---
import Layout from '../layouts/Layout.astro';
import RegisterForm from '../components/RegisterForm';

if (Astro.locals.user) {
  return Astro.redirect('/');
}
---

<Layout title="Register">
  <main class="flex min-h-screen items-center justify-center p-6">
    <div class="w-full max-w-md">
      <div class="mb-8 text-center">
        <span class="text-5xl">⚽</span>
        <h1 class="mt-4 text-2xl font-semibold text-[var(--color-text-heading)]">Create account</h1>
        <p class="mt-1 text-[var(--color-text)]">Join the 2026 World Cup prediction league</p>
      </div>
      <RegisterForm client:load />
      <p class="mt-6 text-center text-sm text-[var(--color-text)]">
        Already have an account? <a href="/login" class="text-[var(--color-accent)] hover:underline">Sign in</a>
      </p>
    </div>
  </main>
</Layout>
