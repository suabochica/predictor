---
import Layout from '../layouts/Layout.astro';
import AppCard from '../components/AppCard';

const user = Astro.locals.user;
---

<Layout title="Dashboard">
  <main class="flex min-h-screen flex-col items-center justify-center gap-10 p-6">
    <div class="text-center">
      <h1 class="text-3xl font-semibold text-[var(--color-text-heading)]">
        Welcome back{user?.email ? `, ${user.email}` : ''}
      </h1>
      <p class="mt-2 text-[var(--color-text)]">Choose an app to continue</p>
    </div>

    <div class="grid w-full max-w-2xl grid-cols-1 gap-6 sm:grid-cols-2">
      <AppCard name="Polla" description="Predict World Cup match scores and climb the leaderboard" href="/polla/" icon="⚽" />
      <AppCard name="Fantasy" description="Draft players, manage your squad, and dominate the standings" href="/fantasy/" icon="🏆" />
    </div>

    <form method="POST" action="/auth/signout">
      <button type="submit" class="text-sm text-[var(--color-text)] hover:text-[var(--color-text-heading)] underline">
        Sign out
      </button>
    </form>
  </main>
</Layout>
