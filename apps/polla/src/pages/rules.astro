---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Scoring Rules">
  <main class="max-w-3xl mx-auto p-6">
    <header class="text-center mb-8">
      <h1 class="text-3xl font-bold">📋 Scoring Rules</h1>
      <p class="mt-2 text-gray-800">
        Understand how points are calculated for your predictions
      </p>
    </header>

    <div class="space-y-8 text-gray-800">
      <section>
        <h2 class="text-xl font-semibold text-gray-800 mb-3">
          Tournament Structure
        </h2>
        <p>
          Football tournaments are structured with an initial group stage or
          round-robin phase, followed by knockout rounds. For all matches, users
          can predict the result.
        </p>
      </section>

      <section>
        <h2 class="text-xl font-semibold text-gray-800 mb-3">
          Prediction Rules
        </h2>
        <ul class="list-disc list-inside space-y-2">
          <li>
            You can change your prediction up to <strong class="text-gray-950"
              >10 minutes before</strong
            > the match starts.
          </li>
          <li>
            Predictions cover <strong class="text-gray-950">90 minutes</strong> of
            regular time + stoppage time only (excludes extra time and penalties).
          </li>
        </ul>
      </section>

      <section>
        <h2 class="text-xl font-semibold text-gray-800 mb-3">
          Scoring Summary
        </h2>
        <div class="overflow-x-auto rounded-xl border border-white/10">
          <table class="w-full text-sm">
            <thead
              class="bg-white/5 text-gray-800 uppercase text-xs tracking-wide"
            >
              <tr>
                <th class="px-4 py-3 text-left">Category</th>
                <th class="px-4 py-3 text-center">First Round</th>
                <th class="px-4 py-3 text-center">Knockout</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-white/10">
              <tr
                ><td class="px-4 py-3">Correct result (winner/draw)</td><td
                  class="px-4 py-3 text-center font-semibold">5</td
                ><td class="px-4 py-3 text-center font-semibold">10</td></tr
              >
              <tr
                ><td class="px-4 py-3">Correct home team goals</td><td
                  class="px-4 py-3 text-center font-semibold">2</td
                ><td class="px-4 py-3 text-center font-semibold">4</td></tr
              >
              <tr
                ><td class="px-4 py-3">Correct away team goals</td><td
                  class="px-4 py-3 text-center font-semibold">2</td
                ><td class="px-4 py-3 text-center font-semibold">4</td></tr
              >
              <tr
                ><td class="px-4 py-3">Correct goal difference</td><td
                  class="px-4 py-3 text-center font-semibold">1</td
                ><td class="px-4 py-3 text-center font-semibold">2</td></tr
              >
              <tr class="bg-white/5"
                ><td class="px-4 py-3 font-bold text-gray-800">MAX TOTAL</td><td
                  class="px-4 py-3 text-center font-bold text-gray-800">10</td
                ><td class="px-4 py-3 text-center font-bold text-gray-800"
                  >20</td
                ></tr
              >
            </tbody>
          </table>
        </div>
      </section>
    </div>

    <nav class="mt-8 flex justify-center gap-8">
      <a href="/polla/" class="text-emerald-400 hover:underline"
        >← Back to Home</a
      >
      <a href="/polla/predictions" class="text-emerald-400 hover:underline"
        >Make Predictions →</a
      >
    </nav>
  </main>
</Layout>
