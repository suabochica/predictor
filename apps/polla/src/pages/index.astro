---
import Layout from '../layouts/Layout.astro';
import { supabase } from '@predictor/supabase';

// Server-side session check (middleware also guards this route)
const user = Astro.locals.user;
---

<Layout title="Home">
  <main class="min-h-screen bg-gray-950 text-white p-6">
    <section class="text-center py-12">
      <span class="text-6xl">🏆</span>
      <h1 class="mt-4 text-4xl font-bold">FIFA World Cup 2026</h1>
      <p class="mt-3 text-gray-400 text-lg max-w-xl mx-auto">
        Predict match scores and compete with friends. Earn points based on accuracy!
      </p>
    </section>

    {user && (
      <div class="flex items-center justify-center gap-4 mb-8">
        <span class="text-gray-300">Welcome, <strong class="text-cyan-400">{user.email}</strong>!</span>
        <form method="POST" action="/polla/auth/signout">
          <button type="submit" class="px-3 py-1.5 text-sm rounded-lg border border-white/20 text-gray-300 hover:bg-white/10 transition-colors">
            Sign out
          </button>
        </form>
      </div>
    )}

    <nav class="grid grid-cols-1 sm:grid-cols-3 gap-4 max-w-2xl mx-auto">
      <a href="/polla/predictions" class="flex flex-col items-center gap-2 rounded-xl border border-white/10 bg-white/5 p-6 hover:border-emerald-500 transition-colors">
        <span class="text-3xl">⚽</span>
        <span class="font-medium">Make Predictions</span>
      </a>
      <a href="/polla/leaderboard" class="flex flex-col items-center gap-2 rounded-xl border border-white/10 bg-white/5 p-6 hover:border-emerald-500 transition-colors">
        <span class="text-3xl">📊</span>
        <span class="font-medium">Leaderboard</span>
      </a>
      <a href="/polla/rules" class="flex flex-col items-center gap-2 rounded-xl border border-white/10 bg-white/5 p-6 hover:border-emerald-500 transition-colors">
        <span class="text-3xl">📋</span>
        <span class="font-medium">Scoring Rules</span>
      </a>
    </nav>

    <footer class="mt-16 text-center text-sm text-gray-500">
      World Cup 2026 • June 11 – July 19, 2026
    </footer>
  </main>
</Layout>
