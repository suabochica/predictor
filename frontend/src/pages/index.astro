---
import Layout from '../layouts/Layout.astro';
import '../styles/home.css';
---

<Layout title="Home">
  <main class="home-page">
    <section class="hero">
      <span class="trophy">🏆</span>
      <h1>FIFA World Cup 2026</h1>
      <p class="subtitle">Predict match scores and compete with friends. Earn points based on accuracy!</p>
    </section>

    <section id="user-section" class="user-section hidden">
      <div class="user-welcome">
        <span class="welcome-text">Welcome, <span id="user-name"></span>!</span>
        <button id="logout-btn" class="logout-button">Sign Out</button>
      </div>
    </section>

    <nav class="nav-menu">
      <a href="/predictions" class="nav-link predictions">
        <span>Make Predictions</span>
        <span class="icon">⚽</span>
      </a>
      <a href="/leaderboard" class="nav-link leaderboard">
        <span>Leaderboard</span>
        <span class="icon">📊</span>
      </a>
      <a href="/rules" class="nav-link rules">
        <span>Scoring Rules</span>
        <span class="icon">📋</span>
      </a>
    </nav>

    <footer class="footer">
      <p>World Cup 2026 • June 11 - July 19, 2026</p>
    </footer>
  </main>
</Layout>

<script>
  function init() {
    const userSection = document.getElementById('user-section');
    const userNameSpan = document.getElementById('user-name');
    const logoutBtn = document.getElementById('logout-btn');

    // Check if user is logged in
    const userJson = localStorage.getItem('worldCupUser');

    if (!userJson) {
      // Redirect to login if not authenticated
      window.location.href = '/login';
      return;
    }

    if (userSection && userNameSpan && logoutBtn) {
      try {
        const user = JSON.parse(userJson);
        userNameSpan.textContent = user.name;
        userSection.classList.remove('hidden');
      } catch {
        // Invalid data, remove it and redirect to login
        localStorage.removeItem('worldCupUser');
        window.location.href = '/login';
      }
    }

    // Handle logout
    logoutBtn?.addEventListener('click', () => {
      localStorage.removeItem('worldCupUser');
      window.location.href = '/login';
    });
  }

  // Run immediately for faster redirect
  init();
</script>

<style>
  .user-section {
    margin-bottom: 2rem;
    text-align: center;
  }

  .user-section.hidden {
    display: none;
  }

  .user-welcome {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .welcome-text {
    color: #e2e8f0;
    font-size: 1.1rem;
    font-weight: 500;
  }

  #user-name {
    color: #4cc9f0;
    font-weight: 600;
  }

  .logout-button {
    padding: 0.5rem 1rem;
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 6px;
    color: #e2e8f0;
    font-size: 0.875rem;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .logout-button:hover {
    background: rgba(255, 255, 255, 0.2);
    border-color: rgba(255, 255, 255, 0.3);
  }

  @media (max-width: 768px) {
    .welcome-text {
      font-size: 1rem;
    }

    .logout-button {
      padding: 0.4rem 0.75rem;
      font-size: 0.8rem;
    }
  }
</style>